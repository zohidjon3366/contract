rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Umumiy ish maydoni: Firebase Authentication orqali kirgan barcha ichki foydalanuvchilar
    // bir xil korxonalar, shartnomalar, schetlar, fakturalar va audit tarixini ko'radi.
    match /workspaces/{workspaceId} {
      allow read, create, update, delete: if request.auth != null;
      match /{document=**} {
        allow read, create, update, delete: if request.auth != null;
      }
    }

    // v7 dagi shaxsiy ma'lumotlarni v8 ga bir martalik ko'chirish uchun.
    match /users/{userId} {
      allow read, create, update, delete:
        if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, create, update, delete:
          if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
